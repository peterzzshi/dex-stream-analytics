# ============================================================================
# Event Ingester - Environment Variables
# ============================================================================
# Copy this file to .env:
#   cp .env.example .env
#
# Then edit .env with your values. ALL variables are REQUIRED.
# The application will fail to start if any are missing.
# ============================================================================

# REQUIRED: Polygon RPC WebSocket endpoint
# ⚠️  MUST use WebSocket (wss://) not HTTP (https://)
#
# Get free API key from:
#   • Alchemy: https://www.alchemy.com/ (recommended)
#     Format: wss://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
#   • Infura: https://www.infura.io/
#     Format: wss://polygon-mainnet.infura.io/ws/v3/YOUR-PROJECT-ID
#
POLYGON_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# REQUIRED: DEX pair contract address to monitor
# Example: QuickSwap WMATIC/USDC pair
PAIR_ADDRESS=0x6e7a5FAFcec6BB1e78bAE2A1F0B612012BF14827

# REQUIRED: Application configuration
APP_PORT=3000
LOG_LEVEL=info

# REQUIRED: DAPR configuration
DAPR_HOST=localhost
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001

# REQUIRED: Kafka Pub/Sub configuration
PUBSUB_NAME=kafka-pubsub
TOPIC_TRADING_EVENTS=dex-trading-events
TOPIC_LIQUIDITY_EVENTS=dex-liquidity-events

# REQUIRED: Producer settings
PRODUCER_BATCH_SIZE=100
PRODUCER_FLUSH_INTERVAL=5s
PRODUCER_RETRY_MAX=3